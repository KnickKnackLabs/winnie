#!/usr/bin/env bash
#MISE description="Boot a disk image headless and check for expected GRUB output"
#USAGE flag "-i --image <path>" help="Disk image path" default="disk.img"
#USAGE flag "-t --timeout <secs>" help="Seconds to wait before killing QEMU" default="20"
#USAGE flag "--uefi" help="Boot in UEFI mode"
set -euo pipefail

IMAGE="${usage_image}"
TIMEOUT="${usage_timeout}"
UEFI="${usage_uefi:-false}"

if [[ ! -f "$IMAGE" ]]; then
  echo "Error: $IMAGE not found."
  exit 1
fi

if ! command -v qemu-system-x86_64 &>/dev/null; then
  echo "Error: qemu-system-x86_64 not found. Run: winnie setup"
  exit 1
fi

QEMU_ARGS=(
  qemu-system-x86_64
  -m 512
  -drive "file=$IMAGE,format=raw,if=virtio"
  -boot c
  -nographic
  -serial mon:stdio
)

if [[ "$UEFI" == "true" ]]; then
  OVMF=""
  for candidate in \
    "$(brew --prefix 2>/dev/null)/share/qemu/edk2-x86_64-code.fd" \
    /usr/share/OVMF/OVMF_CODE.fd \
    /usr/share/edk2/x64/OVMF_CODE.fd \
    /usr/share/qemu/OVMF.fd; do
    if [[ -f "$candidate" ]]; then
      OVMF="$candidate"
      break
    fi
  done
  if [[ -z "$OVMF" ]]; then
    echo "Error: UEFI firmware not found."
    exit 1
  fi
  OVMF_VARS="$(dirname "$OVMF")/edk2-i386-vars.fd"
  VARS_TMP=$(mktemp)
  cp "$OVMF_VARS" "$VARS_TMP"
  QEMU_ARGS+=(
    -drive "if=pflash,format=raw,readonly=on,file=$OVMF"
    -drive "if=pflash,format=raw,file=$VARS_TMP"
  )
fi

OUTPUT=$(mktemp)
trap 'rm -f "$OUTPUT" "${VARS_TMP:-}"' EXIT

echo "Booting $IMAGE (timeout: ${TIMEOUT}s)..."

timeout "$TIMEOUT" "${QEMU_ARGS[@]}" > "$OUTPUT" 2>&1 || true

# Strip ANSI escape codes for clean analysis
CLEAN=$(sed 's/\x1b\[[0-9;]*[a-zA-Z]//g; s/\x1b\[[0-9;]*[mHJK]//g' "$OUTPUT")

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Boot output analysis:"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Check for GRUB
if echo "$CLEAN" | grep -qi "GRUB"; then
  echo "  GRUB:    loaded"
else
  echo "  GRUB:    NOT FOUND"
fi

# Check for winnie header
if echo "$CLEAN" | grep -qi "winnie"; then
  echo "  Menu:    winnie header present"
else
  echo "  Menu:    winnie header NOT FOUND"
fi

# Check for ISO entries
ISO_ENTRIES=$(echo "$CLEAN" | grep -oP '\S+\.iso\S*' | sort -u || true)
if [[ -n "$ISO_ENTRIES" ]]; then
  echo "  ISOs detected:"
  echo "$ISO_ENTRIES" | while read -r entry; do
    echo "    - $entry"
  done
else
  echo "  ISOs:    none detected in menu"
fi

# Check for errors
ERRORS=$(echo "$CLEAN" | grep -i "error" | grep -v "No error" | head -5 || true)
if [[ -n "$ERRORS" ]]; then
  echo "  Errors:"
  echo "$ERRORS" | while read -r line; do
    echo "    ! $line"
  done
else
  echo "  Errors:  none"
fi

echo ""
