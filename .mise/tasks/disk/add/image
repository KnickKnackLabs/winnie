#!/usr/bin/env bash
#MISE description="Add an ISO's boot files to a winnie disk image"
#MISE hide=true
#USAGE arg "<iso>" help="Path to ISO file to add"
#USAGE flag "-i --image <path>" help="Disk image path" required
set -euo pipefail

ISO="${usage_iso}"
IMAGE="${usage_image}"

if [[ ! -f "$ISO" ]]; then
  echo "Error: $ISO does not exist or is not a file." >&2
  exit 1
fi

if [[ ! -f "$IMAGE" ]]; then
  echo "Error: $IMAGE does not exist or is not a file." >&2
  exit 1
fi

ISO_SIZE=$(stat -f%z "$ISO" 2>/dev/null || stat -c%s "$ISO" 2>/dev/null)
IMAGE_SIZE=$(stat -f%z "$IMAGE" 2>/dev/null || stat -c%s "$IMAGE" 2>/dev/null)

if [[ "$ISO_SIZE" -ge "$IMAGE_SIZE" ]]; then
  echo "Error: not enough space — ISO ($(( ISO_SIZE / 1048576 ))MB) is larger than image ($(( IMAGE_SIZE / 1048576 ))MB)." >&2
  exit 1
fi

if ! command -v docker &>/dev/null; then
  echo "Error: docker is required for disk:add --image." >&2
  exit 1
fi

if ! docker info &>/dev/null 2>&1; then
  echo "Error: Docker daemon is not running." >&2
  exit 1
fi

# --- Step 1: Extract boot files from ISO on the host ---

EXTRACT_PARENT="${WINNIE_TMPDIR:-$(dirname "$IMAGE")/.winnie-tmp}"
mkdir -p "$EXTRACT_PARENT"
EXTRACT_DIR=$(mktemp -d "$EXTRACT_PARENT/extract.XXXXXX")
cleanup_extract() {
  rm -rf "$EXTRACT_DIR"
  if [[ -z "${WINNIE_TMPDIR:-}" ]]; then
    if ! rmdir "$EXTRACT_PARENT" 2>/dev/null; then
      :
    fi
  fi
}
trap cleanup_extract EXIT

ISO_BASENAME="$(basename "$ISO" .iso)"
echo "Extracting boot files from $ISO_BASENAME..."
mise run -q iso:extract -- "$ISO" --output "$EXTRACT_DIR"

if [[ ! -f "$EXTRACT_DIR/manifest.json" ]]; then
  echo "Error: iso:extract did not produce a manifest." >&2
  exit 1
fi

# --- Step 2: Copy extracted files to disk image via Docker ---

SLUG="$ISO_BASENAME"
IMAGE_BASENAME="$(basename "$IMAGE")"

echo "Adding $SLUG to $IMAGE_BASENAME..."

docker run --rm --privileged \
  --platform linux/amd64 \
  -e "SLUG=$SLUG" \
  -e "IMAGE_BASENAME=$IMAGE_BASENAME" \
  -v "$(cd "$(dirname "$IMAGE")" && pwd)":/out \
  -v "$EXTRACT_DIR":/extract:ro \
  -v "$MISE_CONFIG_ROOT/lib/grub-gen.sh":/usr/local/lib/grub-gen.sh:ro \
  debian:bookworm bash -c '
set -euo pipefail

apt-get update -qq
apt-get install -y -qq kpartx jq >/dev/null 2>&1

LOOPDEV=$(losetup -f --show /out/$IMAGE_BASENAME)
kpartx -av "$LOOPDEV" >/dev/null 2>&1
LOOPNAME=$(basename "$LOOPDEV")
PART_DATA="/dev/mapper/${LOOPNAME}p3"

MOUNT_DATA=$(mktemp -d)
mount "$PART_DATA" "$MOUNT_DATA"
DISTRO_DIR="$MOUNT_DATA/distros/$SLUG"

if [[ -d "$DISTRO_DIR" ]]; then
  echo "$SLUG already exists on the image. Replacing..."
  rm -rf "$DISTRO_DIR"
fi

mkdir -p "$DISTRO_DIR"
cp -R /extract/. "$DISTRO_DIR/"
echo "  Copied files to /distros/$SLUG/"

# --- Regenerate grub.cfg from all manifests ---

source /usr/local/lib/grub-gen.sh
grub_generate "$MOUNT_DATA"

for manifest in "$MOUNT_DATA"/distros/*/manifest.json; do
  [[ -f "$manifest" ]] || continue
  slug=$(basename "$(dirname "$manifest")")
  title=$(jq -r ".title" "$manifest")
  echo "  GRUB entry: $title ($slug)"
done

echo ""
echo "Distros on image:"
ls -d "$MOUNT_DATA"/distros/*/ 2>/dev/null | while read -r d; do
  s=$(basename "$d")
  t=$(jq -r ".title" "$d/manifest.json" 2>/dev/null || echo "?")
  echo "  $s — $t"
done

sync
umount "$MOUNT_DATA"
kpartx -dv "$LOOPDEV" >/dev/null 2>&1
losetup -d "$LOOPDEV"
echo "Done."
'
