#!/usr/bin/env bash
#MISE description="Format a block device as a winnie multiboot drive"
#MISE hide=true
#USAGE flag "-d --device <device>" help="Block device (e.g., /dev/sdb)" required
#USAGE flag "--arch <arch>" help="Target architectures (default: all)" var=#true
#USAGE flag "-y --yes" help="Skip confirmation prompt"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

DEVICE="${usage_device}"
SKIP_CONFIRM="${usage_yes:-false}"

# Parse arch filter — default is all arches
ARCHES=()
while IFS= read -r arch; do
  ARCHES+=("$arch")
done < <(parse_arch_flags "${usage_arch:-}")

LABEL="WINNIE"
BIOS_BOOT_SIZE="2M"
EFI_SIZE="256M"

# ── Preflight checks ──────────────────────────────────────────────

if [[ "$(uname)" != "Linux" ]]; then
  echo "Error: device formatting requires Linux."
  exit 1
fi

if ! command -v docker &>/dev/null; then
  echo "Error: docker is required for disk:format --device."
  echo "Install Docker Desktop or Docker Engine."
  exit 1
fi

if ! docker info &>/dev/null 2>&1; then
  echo "Error: Docker daemon is not running."
  exit 1
fi

# Validate device
if [[ ! -b "$DEVICE" ]]; then
  echo "Error: $DEVICE is not a block device."
  exit 1
fi

# Safety: refuse to format non-removable drives
removable_path="/sys/block/$(basename "$DEVICE")/removable"
if [[ -f "$removable_path" ]]; then
  if [[ "$(cat "$removable_path")" != "1" ]]; then
    echo "Error: $DEVICE does not appear to be a removable drive."
    echo "If you're sure, check /sys/block/$(basename "$DEVICE")/removable"
    exit 1
  fi
fi

# ── Confirmation ──────────────────────────────────────────────────

echo "winnie: format"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
if ! lsblk "$DEVICE" 2>/dev/null; then :; fi
echo ""
echo "This will DESTROY all data on $DEVICE and create:"
echo "  Part 1: BIOS Boot     ($BIOS_BOOT_SIZE)"
echo "  Part 2: EFI System    ($EFI_SIZE, FAT32)"
echo "  Part 3: Data          (remaining, ext4, label: $LABEL)"
echo ""
echo "GRUB targets: ${ARCHES[*]}"
echo ""

SKIP_CONFIRM="$SKIP_CONFIRM" confirm_or_exit "Proceed with formatting $DEVICE?"

# ── Unmount any existing partitions ───────────────────────────────

echo "Unmounting existing partitions..."
for part in "${DEVICE}"*; do
  if mountpoint -q "$part" 2>/dev/null || mount | grep -q "^$part "; then
    if ! umount "$part" 2>/dev/null; then :; fi
  fi
done

# ── Format via Docker ─────────────────────────────────────────────

docker run --rm --privileged \
  -v "$MISE_CONFIG_ROOT":/repo:ro \
  debian:bookworm \
  bash /repo/lib/format-inner.sh device "$DEVICE" "${ARCHES[@]}"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "winnie: $DEVICE is ready! (${ARCHES[*]})"
echo ""
echo "Next steps:"
echo "  winnie disk:add <iso-file> -d $DEVICE"
echo ""
echo "Boot from USB when done."
