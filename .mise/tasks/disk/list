#!/usr/bin/env bash
#MISE description="List distros on a winnie disk"
#USAGE flag "-d --device <device>" help="Block device (e.g., /dev/sdb)" required
set -euo pipefail

DEVICE="${usage_device}"

# Find the data partition (partition 3)
if [[ "$DEVICE" =~ [0-9]$ ]]; then
  PART_DATA="${DEVICE}p3"
else
  PART_DATA="${DEVICE}3"
fi

if [[ ! -b "$PART_DATA" ]]; then
  echo "Error: $PART_DATA not found. Is $DEVICE a winnie disk?" >&2
  exit 1
fi

# Check if already mounted
MOUNT_POINT=$(findmnt -n -o TARGET "$PART_DATA" 2>/dev/null || true)
MOUNTED_BY_US=false

if [[ -z "$MOUNT_POINT" ]]; then
  MOUNT_POINT=$(mktemp -d)
  mount -o ro "$PART_DATA" "$MOUNT_POINT"
  MOUNTED_BY_US=true
  trap 'umount "$MOUNT_POINT" 2>/dev/null; rmdir "$MOUNT_POINT" 2>/dev/null' EXIT
fi

DISTROS_DIR="$MOUNT_POINT/distros"
if [[ ! -d "$DISTROS_DIR" ]]; then
  echo "No /distros directory found. Is $DEVICE a winnie disk?" >&2
  exit 1
fi

echo "winnie: $DEVICE"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

count=0
for dir in "$DISTROS_DIR"/*/; do
  [[ -d "$dir" ]] || continue
  slug=$(basename "$dir")
  if [[ -f "$dir/manifest.json" ]]; then
    title=$(jq -r '.title' "$dir/manifest.json")
    kernel=$(jq -r '.kernel_path' "$dir/manifest.json" | xargs basename)
    has_squashfs="no"
    [[ -n "$(jq -r '.squashfs_path // empty' "$dir/manifest.json")" ]] && has_squashfs="yes"
    size=$(du -sh "$dir" | cut -f1)
    printf "  %-40s %8s  %s\n" "$slug" "$size" "$title"
  else
    printf "  %-40s %8s  %s\n" "$slug" "?" "(no manifest)"
  fi
  count=$((count + 1))
done

if [[ $count -eq 0 ]]; then
  echo "  No distros found."
  echo ""
  echo "  Add one with: winnie disk:add <iso-file> -d $DEVICE"
fi

echo ""
echo "$count distro(s) on drive."
