#!/usr/bin/env bash
#MISE description="Dump a physical device to a disk image"
#USAGE flag "-d --device <device>" help="Block device (e.g., /dev/disk4)" required
#USAGE flag "-i --image <path>" help="Output image path" required
#USAGE flag "--full" help="Dump entire device (default for whole disks: compact, stops after last partition)"
#USAGE flag "-y --yes" help="Skip confirmation prompt"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

DEVICE="${usage_device:-}"
IMAGE="${usage_image:-}"
SKIP_CONFIRM="${usage_yes:-false}"
FULL="${usage_full:-false}"

# ── Validate inputs ──────────────────────────────────────────────

if [[ -z "$DEVICE" || -z "$IMAGE" ]]; then
  echo "Usage: disk:dump --device <device> --image <path>" >&2
  echo "" >&2
  echo "  Dump a physical device or partition to a disk image." >&2
  echo "" >&2
  echo "  disk:dump --device /dev/disk4    --image usb.img      Compact dump (partitions only)" >&2
  echo "  disk:dump --device /dev/disk4    --image usb.img --full  Dump entire device" >&2
  echo "  disk:dump --device /dev/disk4s3  --image part3.img       Dump a single partition" >&2
  exit 1
fi

if [[ -e "$IMAGE" ]]; then
  echo "Error: $IMAGE already exists. Remove it first." >&2
  exit 1
fi

# ── Platform-specific device checks ─────────────────────────────

OS="$(uname)"

if [[ "$OS" == "Darwin" ]]; then
  if ! diskutil info "$DEVICE" &>/dev/null; then
    echo "Error: $DEVICE is not a valid disk." >&2
    exit 1
  fi

  # Safety: refuse to dump anything on the boot disk
  BOOT_DISK=$(diskutil info / | awk '/Part of Whole:/ {print $NF}')
  DEVICE_WHOLE=$(diskutil info "$DEVICE" | awk '/Part of Whole:/ {print $NF}')
  if [[ "$DEVICE_WHOLE" == "$BOOT_DISK" ]]; then
    echo "Error: refusing to dump the boot disk ($DEVICE)." >&2
    exit 1
  fi

  DEVICE_SIZE=$(diskutil info "$DEVICE" | awk '/Disk Size:/ {print $3 " " $4}')
  DEVICE_SIZE_BYTES=$(diskutil info "$DEVICE" | awk '/Disk Size:/ {gsub(/[()]/, ""); for(i=1;i<=NF;i++) if($i ~ /^[0-9]+$/ && $(i+1)=="Bytes") print $i}')
  DEVICE_NAME=$(diskutil info "$DEVICE" | awk -F: '/Media Name:/ {gsub(/^[ \t]+/, "", $2); print $2}')
  IS_WHOLE=$(diskutil info "$DEVICE" | awk '/^   Whole:/ {print $NF}')
  RAW_DEVICE="/dev/r$(basename "$DEVICE")"

  # ── Find end of last partition (for compact mode + warning) ──
  DUMP_BYTES=""
  COMPACT_BYTES=""
  if [[ "$IS_WHOLE" == "Yes" ]]; then
    LAST_END=0
    while IFS= read -r part_id; do
      [[ -n "$part_id" ]] || continue
      offset=$(diskutil info "/dev/$part_id" | awk '/Partition Offset:/ {print $3}')
      size=$(diskutil info "/dev/$part_id" | awk '/Disk Size:/ {gsub(/[()]/, ""); for(i=1;i<=NF;i++) if($i ~ /^[0-9]+$/ && $(i+1)=="Bytes") print $i}')
      end=$((offset + size))
      [[ "$end" -gt "$LAST_END" ]] && LAST_END="$end"
    done < <(diskutil list "$DEVICE" | awk '/^ *[1-9][0-9]*:/ {print $NF}')

    if [[ "$LAST_END" -gt 0 ]]; then
      COMPACT_BYTES="$LAST_END"
      if [[ "$FULL" != "true" ]]; then
        DUMP_BYTES="$LAST_END"
      fi
    fi
  fi

elif [[ "$OS" == "Linux" ]]; then
  if [[ ! -b "$DEVICE" ]]; then
    echo "Error: $DEVICE is not a block device." >&2
    exit 1
  fi

  # Safety: refuse to dump the root disk
  root_dev=$(findmnt -n -o SOURCE / 2>/dev/null || true)
  if [[ -n "$root_dev" ]]; then
    root_disk=$(lsblk -ndo PKNAME "$root_dev" 2>/dev/null || true)
    root_disk="${root_disk:-$(basename "$root_dev")}"
    dev_base=$(basename "$DEVICE")
    dev_parent=$(lsblk -ndo PKNAME "$DEVICE" 2>/dev/null || true)
    if [[ "$dev_base" == "$root_disk" || "$dev_parent" == "$root_disk" ]]; then
      echo "Error: refusing to dump the root disk ($DEVICE)." >&2
      exit 1
    fi
  fi

  IS_WHOLE="Yes"
  dev_type=$(lsblk -ndo TYPE "$DEVICE" 2>/dev/null)
  [[ "$dev_type" == "part" ]] && IS_WHOLE="No"

  DEVICE_SIZE=$(lsblk -dn -o SIZE "$DEVICE" 2>/dev/null || echo "unknown")
  DEVICE_SIZE_BYTES=$(lsblk -bdn -o SIZE "$DEVICE" 2>/dev/null || echo "0")
  DEVICE_NAME=$(lsblk -dn -o MODEL "$DEVICE" 2>/dev/null || echo "unknown")
  RAW_DEVICE="$DEVICE"

  # ── Find end of last partition (for compact mode + warning) ──
  DUMP_BYTES=""
  COMPACT_BYTES=""
  if [[ "$IS_WHOLE" == "Yes" ]]; then
    LAST_END=0
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      start=$(echo "$line" | awk '{print $1}')
      size=$(echo "$line" | awk '{print $2}')
      end=$((start + size))
      [[ "$end" -gt "$LAST_END" ]] && LAST_END="$end"
    done < <(lsblk -brnp -o START,SIZE "$DEVICE" | tail -n +2)

    if [[ "$LAST_END" -gt 0 ]]; then
      COMPACT_BYTES="$LAST_END"
      if [[ "$FULL" != "true" ]]; then
        DUMP_BYTES="$LAST_END"
      fi
    fi
  fi

else
  echo "Error: unsupported platform ($OS)." >&2
  exit 1
fi

# ── Determine dump size ──────────────────────────────────────────

if [[ -n "$DUMP_BYTES" ]]; then
  DUMP_SIZE_HUMAN=$(human_bytes "$DUMP_BYTES")
  DUMP_MODE="compact"
else
  DUMP_BYTES="$DEVICE_SIZE_BYTES"
  DUMP_SIZE_HUMAN="$DEVICE_SIZE"
  DUMP_MODE="full"
fi

# ── Confirmation ─────────────────────────────────────────────────

echo "winnie: dump"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "  Device:  $DEVICE ($DEVICE_SIZE)"
echo "  Name:    ${DEVICE_NAME:-unknown}"
echo "  Output:  $IMAGE ($DUMP_SIZE_HUMAN)"
if [[ "$DUMP_MODE" == "compact" ]]; then
  echo "  Mode:    compact (through last partition, use --full for entire device)"
else
  if [[ "$IS_WHOLE" == "Yes" && -n "$COMPACT_BYTES" ]]; then
    echo ""
    echo "  ⚠  --full: dumping entire device. This may take a long time."
    echo "     Without --full, this would be $(human_bytes "$COMPACT_BYTES") (compact)."
  fi
fi
echo ""

SKIP_CONFIRM="$SKIP_CONFIRM" confirm_or_exit "Dump $DEVICE to $IMAGE?"

# ── Unmount ──────────────────────────────────────────────────────

echo "Unmounting $DEVICE..."
if [[ "$OS" == "Darwin" ]]; then
  if [[ "$IS_WHOLE" == "Yes" ]]; then
    diskutil unmountDisk "$DEVICE" 2>/dev/null || true
  else
    diskutil unmount "$DEVICE" 2>/dev/null || true
  fi
else
  if [[ "$IS_WHOLE" == "Yes" ]]; then
    for part in "${DEVICE}"*; do
      if mount | grep -q "^$part "; then
        umount "$part" 2>/dev/null || true
      fi
    done
  else
    if mount | grep -q "^$DEVICE "; then
      umount "$DEVICE" 2>/dev/null || true
    fi
  fi
fi

# ── Dump ─────────────────────────────────────────────────────────

echo "Reading $RAW_DEVICE → $IMAGE ..."
BS="4m"
[[ "$OS" == "Linux" ]] && BS="4M"

if [[ "$DUMP_MODE" == "compact" ]]; then
  # Round up to nearest 4MB block — overshoot is harmless free space
  BS_BYTES=4194304
  DUMP_BLOCKS=$(( (DUMP_BYTES + BS_BYTES - 1) / BS_BYTES ))
  sudo dd if="$RAW_DEVICE" of="$IMAGE" bs="$BS" count="$DUMP_BLOCKS" status=progress 2>&1
else
  sudo dd if="$RAW_DEVICE" of="$IMAGE" bs="$BS" status=progress 2>&1
fi

sync

IMAGE_SIZE=$(stat -f%z "$IMAGE" 2>/dev/null || stat -c%s "$IMAGE" 2>/dev/null)

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Done! $IMAGE ($(human_bytes "$IMAGE_SIZE"))"
echo ""
echo "Inspect with:"
echo "  winnie disk:inspect --image $IMAGE"
