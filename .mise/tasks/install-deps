#!/usr/bin/env bash
#MISE description="Install system dependencies not available via mise"
set -euo pipefail

# Dependencies that mise can't manage (compiled system packages).
# This task detects the platform and package manager, then installs what's missing.

check() {
  command -v "$1" &>/dev/null
}

missing=()

# QEMU — needed for VM testing
if ! check qemu-system-x86_64; then
  missing+=("qemu")
fi

# grub-install — needed for format task (Linux only)
if [[ "$(uname)" == "Linux" ]]; then
  if ! check grub-install && ! check grub2-install; then
    missing+=("grub")
  fi
  if ! check sgdisk; then
    missing+=("sgdisk")
  fi
  if ! check mkfs.ext4; then
    missing+=("mkfs")
  fi
fi

if [[ ${#missing[@]} -eq 0 ]]; then
  echo "All system dependencies are installed."
  exit 0
fi

echo "Missing: ${missing[*]}"
echo ""

# Detect package manager
if check brew; then
  PM="brew"
elif check apt-get; then
  PM="apt"
elif check dnf; then
  PM="dnf"
elif check pacman; then
  PM="pacman"
else
  echo "Could not detect a supported package manager."
  echo "Please install manually: ${missing[*]}"
  exit 1
fi

install_brew() {
  local pkgs=()
  for dep in "${missing[@]}"; do
    case "$dep" in
      qemu)   pkgs+=("qemu") ;;
      # grub/sgdisk/mkfs not typically needed on macOS (format is Linux-only)
    esac
  done
  [[ ${#pkgs[@]} -gt 0 ]] && brew install "${pkgs[@]}"
}

install_apt() {
  local pkgs=()
  for dep in "${missing[@]}"; do
    case "$dep" in
      qemu)   pkgs+=("qemu-system-x86") ;;
      grub)   pkgs+=("grub-pc-bin" "grub-efi-amd64-bin" "grub2-common") ;;
      sgdisk) pkgs+=("gdisk") ;;
      mkfs)   pkgs+=("dosfstools" "e2fsprogs") ;;
    esac
  done
  [[ ${#pkgs[@]} -gt 0 ]] && sudo apt-get update && sudo apt-get install -y "${pkgs[@]}"
}

install_dnf() {
  local pkgs=()
  for dep in "${missing[@]}"; do
    case "$dep" in
      qemu)   pkgs+=("qemu-system-x86") ;;
      grub)   pkgs+=("grub2-pc-modules" "grub2-efi-x64-modules" "grub2-tools") ;;
      sgdisk) pkgs+=("gdisk") ;;
      mkfs)   pkgs+=("dosfstools" "e2fsprogs") ;;
    esac
  done
  [[ ${#pkgs[@]} -gt 0 ]] && sudo dnf install -y "${pkgs[@]}"
}

install_pacman() {
  local pkgs=()
  for dep in "${missing[@]}"; do
    case "$dep" in
      qemu)   pkgs+=("qemu-system-x86") ;;
      grub)   pkgs+=("grub") ;;
      sgdisk) pkgs+=("gptfdisk") ;;
      mkfs)   pkgs+=("dosfstools" "e2fsprogs") ;;
    esac
  done
  [[ ${#pkgs[@]} -gt 0 ]] && sudo pacman -S --noconfirm "${pkgs[@]}"
}

echo "Installing via $PM..."
install_"$PM"

echo ""
echo "Done. Re-run to verify:"
echo "  mise run install-deps"
