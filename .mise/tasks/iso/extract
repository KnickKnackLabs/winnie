#!/usr/bin/env bash
#MISE description="Extract boot files from an ISO and write a manifest"
#USAGE arg "<iso>" help="Path to ISO file"
#USAGE flag "-o --output <dir>" help="Output directory for extracted files" required
set -euo pipefail

ISO="$usage_iso"
OUTPUT="$usage_output"

if [[ ! -f "$ISO" ]]; then
  echo "Error: $ISO does not exist." >&2
  exit 1
fi

if ! command -v 7zz &>/dev/null; then
  echo "Error: 7zz not found. Run: mise install" >&2
  exit 1
fi

mkdir -p "$OUTPUT"

WORK=$(mktemp -d)
trap 'rm -rf "$WORK"' EXIT

# --- Step 1: Extract grub.cfg from ISO ---

GRUB_CFG=""
for candidate in boot/grub/grub.cfg boot/grub2/grub.cfg EFI/BOOT/grub.cfg EFI/fedora/grub.cfg; do
  rm -f "$WORK/grub.cfg"
  if 7zz e "$ISO" "$candidate" -o"$WORK" -y >/dev/null 2>&1 && [[ -f "$WORK/grub.cfg" ]]; then
    if grep -q '^menuentry' "$WORK/grub.cfg"; then
      GRUB_CFG="$WORK/grub.cfg"
      break
    fi
  fi
done

if [[ -z "$GRUB_CFG" ]]; then
  echo "Error: no supported grub.cfg with a menuentry found in ISO." >&2
  exit 1
fi

# --- Step 2: Parse first menuentry ---

TITLE=$(awk '
  /^menuentry[[:space:]]*"/ {
    sub(/^menuentry[[:space:]]*"/, "")
    sub(/".*/, "")
    print
    exit
  }
  /^menuentry[[:space:]]*\047/ {
    sub(/^menuentry[[:space:]]*\047/, "")
    sub(/\047.*/, "")
    print
    exit
  }
' "$GRUB_CFG")
if [[ -z "$TITLE" ]]; then
  echo "Error: no menuentry found in grub.cfg." >&2
  exit 1
fi

# Find the linux/initrd lines within the first menuentry block.
# Fedora uses linuxefi/initrdefi; Debian/Ubuntu-style ISOs use linux/initrd.
LINUX_LINE=$(awk '
  /^menuentry/ { in_entry=1 }
  in_entry && /^[[:space:]]*}/ { exit }
  in_entry && /^[[:space:]]*linux(efi)?[[:space:]]/ { print; exit }
' "$GRUB_CFG")
INITRD_LINE=$(awk '
  /^menuentry/ { in_entry=1 }
  in_entry && /^[[:space:]]*}/ { exit }
  in_entry && /^[[:space:]]*initrd(efi)?[[:space:]]/ { print; exit }
' "$GRUB_CFG")

if [[ -z "$LINUX_LINE" ]]; then
  echo "Error: no linux line found in menuentry." >&2
  exit 1
fi

clean_grub_path() {
  local path="$1"
  path="${path#(\$root)}"
  path="${path#/}"
  echo "$path"
}

# Parse kernel path (first arg after 'linux') — strip GRUB root prefix and leading /
KERNEL_PATH=$(clean_grub_path "$(echo "$LINUX_LINE" | awk '{print $2}')")

# Parse boot params (everything after the kernel path)
BOOT_PARAMS=$(echo "$LINUX_LINE" | awk '{$1=""; $2=""; sub(/^[[:space:]]+/, ""); print}' | sed 's/[[:space:]]*---[[:space:]]*$//')

# Parse initrd path — strip leading /
INITRD_PATH=""
if [[ -n "$INITRD_LINE" ]]; then
  INITRD_PATH=$(clean_grub_path "$(echo "$INITRD_LINE" | awk '{print $2}')")
fi

# --- Step 3: Find and extract squashfs ---

# Look for squashfs files in the ISO
SQUASHFS_PATH=$(7zz l "$ISO" 2>/dev/null | awk 'tolower($NF) ~ /(filesystem\.squashfs|squashfs\.img)$/ && first == "" { first = $NF } END { if (first != "") print first }')

# --- Step 4: Extract boot files ---

KERNEL_FILENAME=$(basename "$KERNEL_PATH")
7zz e "$ISO" "$KERNEL_PATH" -o"$OUTPUT" -y >/dev/null 2>&1

if [[ -n "$INITRD_PATH" ]]; then
  INITRD_FILENAME=$(basename "$INITRD_PATH")
  7zz e "$ISO" "$INITRD_PATH" -o"$OUTPUT" -y >/dev/null 2>&1
fi

if [[ -n "$SQUASHFS_PATH" ]]; then
  SQUASHFS_FILENAME=$(basename "$SQUASHFS_PATH")
  7zz e "$ISO" "$SQUASHFS_PATH" -o"$OUTPUT" -y >/dev/null 2>&1
fi

# --- Step 5: Write manifest ---

jq -n \
  --arg title "$TITLE" \
  --arg kernel_path "$KERNEL_PATH" \
  --arg initrd_path "${INITRD_PATH:-}" \
  --arg boot_params "$BOOT_PARAMS" \
  --arg squashfs_path "${SQUASHFS_PATH:-}" \
  '{
    title: $title,
    kernel_path: $kernel_path,
    initrd_path: $initrd_path,
    boot_params: $boot_params,
    squashfs_path: $squashfs_path
  }' > "$OUTPUT/manifest.json"

echo "Extracted: $TITLE"
echo "  Kernel:   $KERNEL_FILENAME"
[[ -n "$INITRD_PATH" ]] && echo "  Initrd:   $INITRD_FILENAME"
[[ -n "$SQUASHFS_PATH" ]] && echo "  Squashfs: $SQUASHFS_FILENAME"
echo "  Manifest: $OUTPUT/manifest.json"
