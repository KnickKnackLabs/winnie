#!/usr/bin/env bash
#MISE description="Download and verify an ISO from the catalog"
#USAGE arg "<distro>" help="Distribution name (alpine, debian, fedora, mint, pop-os)"
#USAGE flag "-v --version <version>" help="Version to download"
#USAGE flag "--arch <arch>" help="Architecture (default: host)" default=""
#USAGE flag "--variant <variant>" help="Variant/channel to download"
#USAGE flag "--force" help="Re-download even if already present"
set -euo pipefail

DISTRO="$usage_distro"
VERSION="${usage_version:-}"
ARCH_FLAG="${usage_arch:-}"
VARIANT="${usage_variant:-}"
FORCE="${usage_force:-false}"
ISO_DIR="${WINNIE_ISO_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/winnie/isos}"
TASK_ROOT="${WINNIE_TASK_ROOT:-$MISE_CONFIG_ROOT}"

mkdir -p "$ISO_DIR"

# --- helpers ---

source "$MISE_CONFIG_ROOT/lib/common.sh"

die() { echo "Error: $*" >&2; exit 1; }

# --- validate distro ---

case "$DISTRO" in
  alpine|debian|fedora|mint|pop-os) ;;
  *) die "unsupported distro '$DISTRO'. Supported: alpine, debian, fedora, mint, pop-os" ;;
esac

# --- resolve version (interactive if not specified) ---

if [[ -z "$VERSION" ]]; then
  arch_args=(); [[ -n "$ARCH_FLAG" ]] && arch_args=(--arch "$ARCH_FLAG")
  versions_json=$(spin "Fetching $DISTRO versions..." mise -C "$TASK_ROOT" run -q "catalog:$DISTRO" -- --json ${arch_args[@]+"${arch_args[@]}"})
  versions=$(echo "$versions_json" | jq -r '.[].version')

  [[ -z "$versions" ]] && die "no versions found for $DISTRO"

  if [[ -t 0 ]]; then
    VERSION=$(echo "$versions" | gum choose --header "Select $DISTRO version:")
  else
    die "no --version specified and stdin is not a terminal"
  fi
fi

# --- fetch ISO details for the chosen version ---

arch_args=(); [[ -n "$ARCH_FLAG" ]] && arch_args=(--arch "$ARCH_FLAG")
detail_json=$(spin "Fetching $DISTRO $VERSION details..." mise -C "$TASK_ROOT" run -q "catalog:$DISTRO" -- --version "$VERSION" --json ${arch_args[@]+"${arch_args[@]}"})

[[ -z "$detail_json" || "$detail_json" == "[]" ]] && die "no ISOs found for $DISTRO $VERSION"

# --- resolve variant (interactive if not specified) ---

if [[ -z "$VARIANT" ]]; then
  # Extract variant field (mint uses "variant", pop-os uses "channel")
  variants=$(echo "$detail_json" | jq -r '.[].variant // .[].channel' | sort -u)
  count=$(echo "$variants" | wc -l | tr -d ' ')

  if [[ "$count" -eq 1 ]]; then
    VARIANT=$(echo "$variants" | head -1)
  elif [[ -t 0 ]]; then
    VARIANT=$(echo "$variants" | gum choose --header "Select variant:")
  else
    die "multiple variants available and stdin is not a terminal. Use --variant"
  fi
fi

# --- find the matching entry ---

entry=$(echo "$detail_json" | jq --arg v "$VARIANT" '
  .[] | select(.variant == $v or .channel == $v)
' | jq -s '.[0]')

[[ -z "$entry" || "$entry" == "null" ]] && die "no entry found for variant '$VARIANT'"

url=$(echo "$entry" | jq -r '.url')
sha256=$(echo "$entry" | jq -r '.sha256 // ""')
filename=$(echo "$entry" | jq -r '.filename')

[[ -z "$url" || "$url" == "null" ]] && die "no download URL for $DISTRO $VERSION $VARIANT"

dest="$ISO_DIR/$filename"

# --- check if already downloaded ---

if [[ -f "$dest" && "$FORCE" != "true" ]]; then
  if [[ -n "$sha256" && "$sha256" != "null" ]]; then
    existing=$(sha256sum "$dest" | awk '{print $1}')
    if [[ "$existing" == "$sha256" ]]; then
      echo "Already downloaded and verified: $dest"
      exit 0
    else
      echo "Existing file has wrong checksum, re-downloading..."
    fi
  else
    echo "Already downloaded: $dest"
    exit 0
  fi
fi

# --- download ---

echo "Downloading $filename..."
echo "  URL: $url"
echo "  Dest: $dest"
echo ""

CURL_ARGS=(-fL -o "$dest")
[[ -t 1 ]] && CURL_ARGS+=(--progress-bar) || CURL_ARGS+=(-sS)
${CURL:-curl} "${CURL_ARGS[@]}" "$url" || die "download failed"

# --- verify ---

if [[ -n "$sha256" && "$sha256" != "null" ]]; then
  echo ""
  echo "Verifying SHA256..."
  actual=$(sha256sum "$dest" | awk '{print $1}')
  if [[ "$actual" == "$sha256" ]]; then
    echo "  Verified: $actual"
  else
    rm -f "$dest"
    die "checksum mismatch!\n  Expected: $sha256\n  Got:      $actual\n  File deleted."
  fi
else
  echo "  No checksum available, skipping verification."
fi

echo ""
echo "Ready: $dest"
