#!/usr/bin/env bash
#MISE description="Deploy latest grub.cfg to an existing disk image (fast iteration)"
#USAGE flag "-i --image <path>" help="Disk image path" default="disk.img"
set -euo pipefail

IMAGE="${usage_image}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

if [[ ! -f "$IMAGE" ]]; then
  echo "Error: $IMAGE not found. Create one with: winnie format-image"
  exit 1
fi

if [[ ! -f "$REPO_DIR/grub/grub.cfg" ]]; then
  echo "Error: grub/grub.cfg not found in repo."
  exit 1
fi

docker run --rm --privileged --platform linux/amd64 \
  -v "$REPO_DIR":/repo:ro \
  -v "$(cd "$(dirname "$IMAGE")" && pwd)":/out \
  debian:bookworm bash -c "
set -euo pipefail
apt-get update -qq && apt-get install -y -qq kpartx 2>&1 | tail -1

LOOPDEV=\$(losetup -f --show /out/$(basename "$IMAGE"))
kpartx -av \$LOOPDEV 2>/dev/null
LN=\$(basename \$LOOPDEV)

MNT=\$(mktemp -d)
mount /dev/mapper/\${LN}p3 \$MNT

cp /repo/grub/grub.cfg \$MNT/boot/grub/grub.cfg
echo \"Deployed grub.cfg (\$(wc -c < /repo/grub/grub.cfg) bytes)\"

sync
umount \$MNT
kpartx -d \$LOOPDEV
losetup -d \$LOOPDEV
" 2>&1
